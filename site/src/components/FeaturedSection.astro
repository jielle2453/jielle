---
const base = import.meta.env.BASE_URL;

const bars = [
  { label: 'before_completion_rate', pct: 92.75, val: '92.75%' },
  { label: 'after_completion_rate', pct: 100.0, val: '100.00%' },
  { label: 'before_sus_score', pct: 52.5, val: '52.50' },
  { label: 'after_sus_score', pct: 72.5, val: '72.50' },
  { label: 'avg_task_time_before_s', pct: 91.0, val: "2'45''" },
  { label: 'avg_task_time_after_s', pct: 65.0, val: "1'59''" },
  { label: 'sample_size_participants', pct: 40.0, val: '4' },
  { label: 'review_codes_analyzed', pct: 78.0, val: '≈200' },
];

const metrics = [
  { label: 'SUS', val: '+20' },
  { label: 'Task time', val: '−46s' },
  { label: 'Completion', val: '100%' },
];
---

<section class="relative py-16 md:py-24">
  <!-- Top rule + label -->
  <div class="flex items-center justify-between label-mono text-ink-faint border-t border-ink/15 pt-4 mb-10">
    <span><span class="text-rust">§ 01</span> — Featured case study</span>
    <span class="text-ink/50">Usability test · n=4 · 2024</span>
  </div>

  <div class="relative">
    <!-- DATA BARS (decoration that glass will blur) -->
    <div class="absolute inset-0 py-4 flex flex-col justify-center gap-[9px] pointer-events-none select-none">
      {
        bars.map((b) => (
          <div class="flex items-center gap-3">
            <span class="font-mono text-[9.5px] uppercase tracking-[0.2em] text-ink-faint/85 w-[230px] shrink-0">
              § {b.label}
            </span>
            <div class="h-[8px] flex-1 bg-paper-dark/70 relative overflow-hidden">
              <div
                class="absolute inset-y-0 left-0 bg-rust/55"
                style={`width: ${b.pct}%`}
              />
            </div>
            <span class="font-mono text-[10px] text-ink-soft/80 tabular-nums w-[70px] text-right">
              {b.val}
            </span>
          </div>
        ))
      }
    </div>

    <!-- GLASS CARD (floats over the data layer, narrower so bars peek out) -->
    <article
      class="relative mx-4 md:mx-20 xl:mx-28 rounded-[18px]
             border border-ink/12 bg-paper/25
             backdrop-blur-[22px] backdrop-saturate-[165%]
             shadow-[0_40px_90px_-45px_rgba(26,24,20,0.42),inset_0_1px_0_0_rgba(243,238,227,0.6)]
             px-6 md:px-10 py-7 md:py-10
             transition-colors duration-500 hover:bg-paper/40"
    >
      <div class="flex flex-col md:flex-row gap-7 md:gap-10 items-start md:items-end">
        <header class="md:min-w-[320px]">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-rust mb-3">
            Chapter One
          </div>
          <h3 class="display text-[52px] md:text-[76px] leading-[0.88] text-ink">
            LinePay
            <span class="display-italic block font-light text-ink-soft">redesign.</span>
          </h3>
          <div class="font-mono text-[10.5px] uppercase tracking-[0.18em] text-ink-faint mt-3">
            NTNU · 2024 · Team of 5
          </div>
        </header>

        <div class="flex-1 md:border-l md:border-ink/15 md:pl-8 space-y-5">
          <p class="text-[15px] leading-[1.55] text-ink max-w-sm">
            Redesigning Taiwan's most-used mobile payment app around one user goal —
            <em class="display-italic text-ink">saving money effortlessly.</em>
          </p>
          <div class="flex flex-wrap gap-2">
            {
              metrics.map((m) => (
                <span class="inline-flex items-baseline gap-1.5 border border-ink/18 px-2.5 py-1 rounded-full bg-paper/65 backdrop-blur">
                  <span class="font-mono text-[9.5px] uppercase tracking-[0.14em] text-ink-faint">
                    {m.label}
                  </span>
                  <span class="font-mono text-xs font-semibold text-rust tabular-nums">
                    {m.val}
                  </span>
                </span>
              ))
            }
          </div>
        </div>

        <a
          href={`${base}linepay`}
          class="group inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.22em] text-ink hover:text-rust transition-colors self-start md:self-end whitespace-nowrap"
        >
          Read study
          <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </article>
  </div>
</section>
