---
interface Props {
  no: string;
  title: string;
  subtitle: string;
  meta?: string[];
  href?: string;
  year?: string;
}

const { no, title, subtitle, meta = [], href = '#', year } = Astro.props;
---

<a
  href={href}
  class="group relative block rounded-[14px] border border-white/12
         bg-white/[0.04] backdrop-blur-[18px] backdrop-saturate-[140%]
         p-6 md:p-7 min-h-[200px]
         shadow-[0_30px_80px_-40px_rgba(0,0,0,0.6),inset_0_1px_0_0_rgba(255,255,255,0.08)]
         transition-all duration-500
         hover:bg-white/[0.07] hover:border-white/20
         hover:-translate-y-0.5"
>
  <header class="flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.2em] text-white/50">
    <span>§ {no}</span>
    {year && <span>{year}</span>}
  </header>

  <h3 class="font-sans font-bold text-[28px] md:text-[34px] leading-[1.02] text-white mt-6 tracking-tight">
    {title}
  </h3>

  <p class="font-sans text-[13px] text-white/65 mt-2 leading-snug max-w-[26ch]">
    {subtitle}
  </p>

  {meta.length > 0 && (
    <ul class="mt-5 font-mono text-[10px] uppercase tracking-[0.18em] text-white/45 space-y-1">
      {meta.map((m) => (
        <li class="flex items-center gap-1.5">
          <span class="size-1 rounded-full bg-white/40"></span>
          {m}
        </li>
      ))}
    </ul>
  )}

  <span class="absolute bottom-5 right-5 font-mono text-[10px] uppercase tracking-[0.22em] text-white/50 group-hover:text-white transition-colors inline-flex items-center gap-1">
    Open
    <span class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
  </span>
</a>
