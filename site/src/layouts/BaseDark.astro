---
import '../styles/global.css';
import LiquidShader from '../components/LiquidShader.svelte';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Portfolio of Jielle Lu — cinematic edition.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="theme-dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
    <style is:global>
      html.theme-dark {
        background-color: #1a1a1a;
        color: #F3EFE6;
      }
      html.theme-dark body {
        background: transparent;
      }
      html.theme-dark ::selection {
        background-color: #d4a017;
        color: #1a1a1a;
      }
    </style>
  </head>
  <body class="relative min-h-screen overflow-x-hidden">
    <LiquidShader client:load />
    <slot />

    <!-- global grain overlay for the dark theme -->
    <div class="pointer-events-none fixed inset-0 z-[60] opacity-[0.12] mix-blend-overlay" aria-hidden="true">
      <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
        <filter id="dark-grain">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.75"
            numOctaves="3"
            seed="9"
            stitchTiles="stitch"
          />
          <feColorMatrix
            values="0 0 0 0 0.5
                    0 0 0 0 0.5
                    0 0 0 0 0.5
                    0 0 0 0.45 0"
          />
        </filter>
        <rect width="100%" height="100%" filter="url(#dark-grain)" />
      </svg>
    </div>
  </body>
</html>
